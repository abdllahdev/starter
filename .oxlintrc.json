{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "categories": {
    "correctness": "error",
    "suspicious": "warn"
  },
  "plugins": [
    "unicorn",
    "typescript",
    "import",
    "promise",
    "oxc",
    "react",
    "react-perf",
    "jsx-a11y",
    "node",
    "jsdoc",
    "vitest"
  ],
  "options": {
    "typeAware": true,
    "typeCheck": true,
    "reportUnusedDisableDirectives": "error"
  },
  "rules": {
    "react/react-in-jsx-scope": "off",
    "import/no-unassigned-import": "off",
    "no-shadow": "off",
    "no-named-as-default": "off"
  },
  "env": {
    "browser": true
  },
  "ignorePatterns": [
    "dist/**",
    "node_modules/**",
    "*.config.ts",
    "*.config.js",
    "**/data/**",
    "**/*.hbs",
    "routeTree.gen.ts"
  ]
}
